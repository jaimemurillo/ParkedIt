<body class="bg-background text-on-background min-h-screen flex flex-col">
<!-- Top Navigation Bar - Minimal for Login State -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-margin-mobile h-16 bg-slate-50 border-b border-slate-200">
<div class="flex items-center gap-sm">
<span class="material-symbols-outlined text-primary" data-icon="school">school</span>
<h1 class="font-headline-sm text-headline-sm text-primary tracking-tight">Campus Parking</h1>
</div>
<div class="hidden md:flex items-center gap-md">
<span class="text-label-sm text-outline">v2.4.0-Stable</span>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center px-margin-mobile pt-16 pb-lg">
<div class="w-full max-w-[400px] flex flex-col gap-lg">
<!-- Branding Section -->
<div class="flex flex-col items-center text-center gap-md">
<div class="w-20 h-20 bg-primary-container rounded-xl flex items-center justify-center shadow-[0_2px_8px_rgba(0,45,98,0.04)]">
<span class="material-symbols-outlined text-on-primary-container text-[40px]" data-icon="account_balance">account_balance</span>
</div>
<div class="space-y-xs">
<h2 class="font-headline-md text-headline-md text-primary">Institutional Login</h2>
<p class="font-body-sm text-body-sm text-on-surface-variant">Access your university parking dashboard with your official credentials.</p>
</div>
</div>
<!-- Login Card -->
<div class="bg-surface-container-lowest rounded-xl p-lg border border-slate-200 shadow-[0_2px_8px_rgba(0,45,98,0.04)]">
<form class="flex flex-col gap-md">
<!-- Email Field -->
<div class="flex flex-col gap-xs">
<label class="font-label-md text-label-md text-on-surface-variant px-1" for="email">University Email</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]" data-icon="mail">mail</span>
<input class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="email" name="email" placeholder="student@university.edu" type="email"/>
</div>
</div>
<!-- Password Field -->
<div class="flex flex-col gap-xs">
<label class="font-label-md text-label-md text-on-surface-variant px-1" for="password">Password</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]" data-icon="lock">lock</span>
<input class="w-full pl-10 pr-12 py-3 bg-surface-container-low border border-outline-variant rounded-lg font-body-md text-body-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" id="password" name="password" placeholder="••••••••" type="password"/>
<button class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-primary" type="button">
<span class="material-symbols-outlined text-[20px]" data-icon="visibility">visibility</span>
</button>
</div>
</div>
<!-- Action Links -->
<div class="flex justify-end">
<a class="font-label-sm text-label-sm text-on-primary-container hover:underline" href="#">Forgot Password?</a>
</div>
<!-- Submit Button -->
<button class="mt-sm w-full py-3 bg-primary text-on-primary font-label-lg text-label-lg rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-sm" type="submit">
                        Login
                        <span class="material-symbols-outlined text-[18px]" data-icon="arrow_forward">arrow_forward</span>
</button>
</form>
</div>
<!-- Decorative Illustration/Context Area -->
<div class="relative rounded-xl overflow-hidden h-32 border border-slate-200">
<div class="absolute inset-0 bg-primary/10 flex items-center justify-center">
<div class="text-center px-md">
<div class="flex items-center justify-center gap-sm mb-xs">
<span class="material-symbols-outlined text-secondary text-[20px]" data-icon="verified_user">verified_user</span>
<span class="font-label-sm text-label-sm text-on-surface uppercase tracking-wider">Secure University Network</span>
</div>
<p class="font-body-sm text-body-sm text-on-surface-variant text-[12px]">Your connection is encrypted using SSL technology for your security.</p>
</div>
